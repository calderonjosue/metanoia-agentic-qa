{
  "info": {
    "name": "Metanoia-QA API",
    "description": "API collection for Metanoia-QA: Autonomous Agentic STLC Framework",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000"
    },
    {
      "key": "sprintId",
      "value": "SP-001"
    }
  ],
  "item": [
    {
      "name": "Sprint Lifecycle",
      "item": [
        {
          "name": "Start Sprint",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sprint_id\": \"{{sprintId}}\",\n  \"sprint_goal\": \"Test checkout flow with payment gateway\",\n  \"risk_tolerance\": \"Low\",\n  \"historical_lookback_sprints\": 3\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/metanoia/sprint/start",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "metanoia", "sprint", "start"]
            },
            "description": "Start a new quality mission for a sprint"
          },
          "response": []
        },
        {
          "name": "Get Sprint Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/metanoia/sprint/{{sprintId}}/status",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "metanoia", "sprint", "{{sprintId}}", "status"]
            },
            "description": "Get the current status of a sprint"
          },
          "response": []
        },
        {
          "name": "Get Test Plan",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/metanoia/sprint/{{sprintId}}/test-plan",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "metanoia", "sprint", "{{sprintId}}", "test-plan"]
            },
            "description": "Get the generated test plan from Strategy Manager"
          },
          "response": []
        },
        {
          "name": "Get Certification Report",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/metanoia/sprint/{{sprintId}}/certification",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "metanoia", "sprint", "{{sprintId}}", "certification"]
            },
            "description": "Get the release certification report"
          },
          "response": []
        },
        {
          "name": "Stop Sprint",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/metanoia/sprint/{{sprintId}}/stop",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "metanoia", "sprint", "{{sprintId}}", "stop"]
            },
            "description": "Stop an active sprint"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Agent Control",
      "item": [
        {
          "name": "List All Agents",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/metanoia/agents/status",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "metanoia", "agents", "status"]
            },
            "description": "Get status of all agents"
          },
          "response": []
