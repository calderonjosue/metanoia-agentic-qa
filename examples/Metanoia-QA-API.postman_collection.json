        {
          "name": "Get Specific Agent",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/metanoia/agents/context-analyst",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "metanoia", "agents", "context-analyst"]
            },
            "description": "Get status of a specific agent"
          },
          "response": []
        },
        {
          "name": "Pause Agent",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/metanoia/agents/context-analyst/pause",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "metanoia", "agents", "context-analyst", "pause"]
            },
            "description": "Pause a specific agent"
          },
          "response": []
        },
        {
          "name": "Resume Agent",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/metanoia/agents/context-analyst/resume",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "metanoia", "agents", "context-analyst", "resume"]
            },
            "description": "Resume a paused agent"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Skills",
      "item": [
        {
          "name": "List Skills",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/metanoia/skills",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "metanoia", "skills"]
            },
            "description": "List all available skills"
          },
          "response": []
        },
        {
          "name": "Execute Playwright Skill",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"skill\": \"playwright-executor\",\n  \"input\": {\n    \"action\": \"goto\",\n    \"url\": \"https://example.com\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/metanoia/skills/execute",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "metanoia", "skills", "execute"]
            },
            "description": "Execute a skill directly"
          },
          "response": []
        },
        {
          "name": "Execute k6 Skill",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"skill\": \"k6-executor\",\n  \"input\": {\n    \"script\": [\n      {\n        \"method\": \"GET\",\n        \"path\": \"/api/products\"\n      }\n    ],\n    \"vus\": 10,\n    \"duration\": \"30s\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/metanoia/skills/execute",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "metanoia", "skills", "execute"]
            },
            "description": "Execute k6 performance test"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Knowledge Base",
      "item": [
        {
          "name": "Search Historical Context",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"checkout payment failures\",\n  \"max_results\": 5\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/metanoia/knowledge/search",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "metanoia", "knowledge", "search"]
            },
            "description": "Search historical testing memory"
          },
          "response": []
        },
        {
          "name": "Add Lesson Learned",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"agent_role\": \"performance_engineer\",\n  \"tool_used\": \"k6\",\n  \"issue_encountered\": \"firewall blocking load test\",\n  \"resolution_applied\": \"use authenticated endpoint with header\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/metanoia/knowledge/lessons",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "metanoia", "knowledge", "lessons"]
            },
            "description": "Add a lesson learned by an agent"
          },
          "response": []
        },
        {
          "name": "Get Lessons Learned",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/metanoia/knowledge/lessons",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "metanoia", "knowledge", "lessons"]
            },
            "description": "Get all lessons learned"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Reports",
      "item": [
        {
          "name": "Get Sprint Report",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/metanoia/reports/sprint/{{sprintId}}",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "metanoia", "reports", "sprint", "{{sprintId}}"]
            },
            "description": "Get comprehensive sprint report"
          },
          "response": []
        },
        {
          "name": "Get Test Results",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/metanoia/reports/sprint/{{sprintId}}/results",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "metanoia", "reports", "sprint", "{{sprintId}}", "results"]
            },
            "description": "Get test execution results"
          },
          "response": []
        },
        {
          "name": "Export Report",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/metanoia/reports/sprint/{{sprintId}}/export?format=json",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "metanoia", "reports", "sprint", "{{sprintId}}", "export"],
              "query": [
                {
                  "key": "format",
                  "value": "json"
                }
              ]
            },
            "description": "Export report in specified format"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Health & Info",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "description": "Check API health status"
          },
          "response": []
        },
        {
          "name": "API Info",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}",
              "host": ["{{baseUrl}}"]
            },
            "description": "Get API information and version"
          },
          "response": []
