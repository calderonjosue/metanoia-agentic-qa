{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WireMock Mapping Schema",
  "type": "object",
  "required": ["request", "response"],
  "properties": {
    "request": {
      "type": "object",
      "required": ["method", "urlPath"],
      "properties": {
        "method": {
          "type": "string",
          "enum": ["ANY", "GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS", "HEAD"]
        },
        "urlPath": {
          "type": "string"
        },
        "urlPattern": {
          "type": "string"
        },
        "urlPathPattern": {
          "type": "string"
        },
        "queryParameters": {
          "type": "object"
        },
        "headers": {
          "type": "object"
        },
        "bodyPatterns": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "equalTo": {"type": "string"},
              "matches": {"type": "string"},
              "contains": {"type": "string"},
              "matchesJsonPath": {"type": "string"}
            }
          }
        },
        "cookies": {
          "type": "object"
        },
        "basicAuthCredentials": {
          "type": "object",
          "properties": {
            "username": {"type": "string"},
            "password": {"type": "string"}
          }
        }
      }
    },
    "response": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": {
          "type": "integer"
        },
        "statusMessage": {
          "type": "string"
        },
        "jsonBody": {
          "type": ["object", "array", "string", "number", "boolean", "null"]
        },
        "body": {
          "type": "string"
        },
        "headers": {
          "type": "object"
        },
        "bodyPatterns": {
          "type": "array"
        },
        "delayDistribution": {
          "type": "object",
          "properties": {
            "type": {"type": "string", "enum": ["fixed", "lognormal", "uniform"]},
            "value": {"type": "integer"}
          }
        },
        "transformers": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "priority": {
      "type": "integer"
    },
    "scenarioName": {
      "type": "string"
    },
    "requiredScenarioState": {
      "type": "string"
    },
    "newScenarioState": {
      "type": "string"
    },
    "persistent": {
      "type": "boolean"
    },
    "postServeActions": {
      "type": "array"
    },
    "metadata": {
      "type": "object"
    }
  }
}
