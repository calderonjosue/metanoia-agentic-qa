# Metanoia-QA Configuration

# API Keys
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-pro

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_key_here
SUPABASE_ANON_KEY=your_anon_key_here

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/metanoia
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=metanoia

# LangGraph Checkpointing
CHECKPOINT_DB_URL=postgresql://postgres:password@localhost:5432/metanoia_checkpoints

# Execution Agents
PLAYWRIGHT_BROWSERS_PATH=/ms-playwright
K6_BINARY_PATH=/usr/local/bin/k6

# Security
ZAP_API_KEY=your_zap_api_key_here
ZAP_BASE_URL=http://localhost:8080

# Application
LOG_LEVEL=INFO
METANOIA_ENV=development
METANOIA_DEBUG=false

# Feature Flags
ENABLE_VISION_HEALING=true
ENABLE_AUTO_PR=true
ENABLE_COMPLIANCE_REPORTS=false
